{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.lovable.app"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        }
      ]
    }
  ],
  "functions": {
    "api/teia.js": {
      "maxDuration": 60
    },
    "api/verificar-rotulos.js": {
      "maxDuration": 30
    },
    "api/criar-andares.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/verificar-rotulos",
      "schedule": "0 */6 * * *"
    }
  ]
}
