# Copie este arquivo para .env (uso local com `vercel dev`) e preencha.
# Na Vercel (produção), configure estas mesmas chaves em:
# Project Settings -> Environment Variables

# Obrigatória — token do Private App do HubSpot (escopos de leitura)
HUBSPOT_TOKEN=

# Opcionais — só mexa se os nomes reais no HubSpot da ATIE forem diferentes
# dos assumidos no documento de contexto do projeto.
# HUBSPOT_PROP_EDIFICIO=aw_edificio_id
# HUBSPOT_PROP_ANDAR=aw_andar_de_interesse
# HUBSPOT_NUCLEO_SOURCE=pipeline
# HUBSPOT_PROP_NUCLEO=nucleo

# Job de verificação de rótulo (/api/verificar-rotulos) — opcionais
# HUBSPOT_PROP_ROTULO_PENDENTE=aw_rotulo_pendente
# CRON_SECRET=defina-uma-string-aleatoria-aqui

# Fase 2 — Custom Objects Andar/Edifício (ver README) — PALPITE, confirme
# na tela "Detalhes da API" antes de confiar
# HUBSPOT_OBJECT_ANDAR=p51253038_andares
# HUBSPOT_OBJECT_EDIFICIO=p51253038_edificios
# HUBSPOT_PROP_ANDAR_NOME=nome_do_andar
# HUBSPOT_PROP_ANDAR_NUMERO=numero_do_andar
# HUBSPOT_PROP_EDIFICIO_NOME=name
# HUBSPOT_PROP_EDIFICIO_CNPJ=cnpj_do_condominio

# Job de criação automática de Andares (/api/criar-andares) — opcionais
# HUBSPOT_PROP_EDIFICIO_ANDARES=andares
# HUBSPOT_LABEL_ANDAR_EDIFICIO=pertence a
